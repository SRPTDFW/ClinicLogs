# Copy this to .env for local testing, or set these in your host's dashboard.

# Long random string — protects login sessions. Generate one with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Passcode used to log in as admin (manage clinics, view all-clinic history)
ADMIN_PASSCODE=change-me-admin-passcode

# Starting passcode assigned to every clinic the first time the app runs.
# Change each clinic's passcode from the admin panel after first login.
DEFAULT_CLINIC_PASSCODE=change-me-clinic-passcode

# Database connection. Leave unset to use a local SQLite file (fine for testing,
# NOT recommended for production — most hosts wipe local files on redeploy).
# For production, set this to a Postgres connection string, e.g. from Neon or
# your host's managed Postgres add-on:
# DATABASE_URL=postgresql://user:password@host/dbname
